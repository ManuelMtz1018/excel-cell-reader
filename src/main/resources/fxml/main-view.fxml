<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.example.excelreader.MainController"
            styleClass="app-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <VBox alignment="CENTER" spacing="0">
            <VBox maxWidth="560.0" spacing="20.0" styleClass="reader-card">
                <padding>
                    <Insets bottom="34.0" left="38.0" right="38.0" top="34.0"/>
                </padding>

                <VBox alignment="CENTER" spacing="8.0">
                    <Label styleClass="lock-icon" text="EX"/>
                    <Label styleClass="title" text="Excel Cell Reader"/>
                    <Label styleClass="subtitle" text="Lee y monitorea una celda especifica desde archivos .xlsx o .xls"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label styleClass="field-label" text="Archivo Excel"/>
                    <HBox spacing="10.0">
                        <TextField fx:id="filePathField"
                                   editable="false"
                                   focusTraversable="false"
                                   HBox.hgrow="ALWAYS"
                                   promptText="Ningun archivo seleccionado"/>
                        <Button onAction="#onSelectFile" styleClass="secondary-button" text="Seleccionar archivo"/>
                    </HBox>
                </VBox>

                <HBox spacing="18.0">
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="field-label" text="Celda"/>
                        <TextField fx:id="cellReferenceField" promptText="A1"/>
                    </VBox>
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="field-label" text="Tipo de dato"/>
                        <ComboBox fx:id="dataTypeComboBox"
                                  maxWidth="Infinity"
                                  promptText="Seleccionar"/>
                    </VBox>
                </HBox>

                <Button maxWidth="Infinity" onAction="#onReadCell" styleClass="primary-button" text="Leer celda"/>

                <VBox spacing="12.0">
                    <Label styleClass="section-label" text="Monitoreo y Mensajeria"/>
                    <HBox spacing="18.0">
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Intervalo (segundos)"/>
                            <TextField fx:id="intervalField" promptText="5"/>
                        </VBox>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Canal"/>
                            <ComboBox fx:id="messageChannelComboBox"
                                      maxWidth="Infinity"
                                      promptText="Seleccionar"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="10.0">
                        <Button fx:id="startMonitorButton"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"
                                onAction="#onStartMonitoring"
                                styleClass="primary-button"
                                text="Iniciar monitoreo"/>
                        <Button fx:id="stopMonitorButton"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"
                                onAction="#onStopMonitoring"
                                styleClass="secondary-button"
                                text="Detener"/>
                    </HBox>
                </VBox>

                <VBox spacing="8.0">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="field-label" text="Resultado"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="statusLabel" styleClass="status-text" text="Listo"/>
                    </HBox>
                    <TextArea fx:id="resultArea" editable="false" prefRowCount="5" wrapText="true"/>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
